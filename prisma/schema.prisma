// Define qual banco de dados usar
datasource db {
  provider = "postgresql"
}

// Gera o cliente Prisma automaticamente
generator client {
  provider = "prisma-client-js"
}

// Tabela de usuários
model User {
  id         Int          @id @default(autoincrement())
  nome       String
  email      String       @unique
  senha      String
  avatar     String?
  criadoEm  DateTime     @default(now())
  lista      UserLista[]
  avaliacoes Avaliacao[]
  progresso  Progresso[]
}

// Tabela de animes
model Anime {
  id        Int          @id @default(autoincrement())
  titulo    String
  sinopse   String
  capa      String?
  generos   String[]
  nota      Float        @default(0)
  ano       Int
  status    String       @default("em_exibicao")
  episodios Episodio[]
  lista     UserLista[]
  avaliacoes Avaliacao[]
  progresso  Progresso[]
}

// Tabela de episódios
model Episodio {
  id          Int    @id @default(autoincrement())
  animeId     Int
  numero      Int
  titulo      String
  descricao   String?
  urlVideo    String
  urlVideoAlt String?           // ← NOVO: URL alternativa (Dailymotion)
  fontePrincipal String @default("youtube") // ← NOVO: "youtube" ou "dailymotion"
  duracao     Int?
  anime       Anime  @relation(fields: [animeId], references: [id])
  progresso   Progresso[]
}

// Lista personalizada do usuário
model UserLista {
  id         Int      @id @default(autoincrement())
  userId     Int
  animeId    Int
  status     String   @default("quero_ver") // assistindo | concluido | quero_ver
  favoritado Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id])
  anime      Anime    @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId]) // Um usuário não pode ter o mesmo anime duas vezes
}

// Avaliações
model Avaliacao {
  id          Int      @id @default(autoincrement())
  userId      Int
  animeId     Int
  nota        Float
  comentario  String?
  criadoEm   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  anime       Anime    @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId]) // Um usuário avalia cada anime uma vez
}
// Salva o progresso do usuário por episódio
model Progresso {
  id         Int      @id @default(autoincrement())
  userId     Int
  episodioId Int
  animeId    Int
  segundos   Int      @default(0)  // Tempo assistido em segundos
  concluido  Boolean  @default(false)
  atualizadoEm DateTime @updatedAt

  user     User     @relation(fields: [userId],     references: [id])
  episodio Episodio @relation(fields: [episodioId], references: [id])
  anime    Anime    @relation(fields: [animeId],    references: [id])

  @@unique([userId, episodioId]) // Um progresso por usuário por episódio
}